{
  "format_version": "1.10.0",
  "render_controllers": {
    "controller.render.outline_cape_layer": {
      "geometry": "Geometry.cape_outline",
      "materials": [ { "*": "Material.outline" } ],
      "textures": [ "Texture.cape" ],
      "part_visibility": [
        { "*": true },
        { "cape": "query.has_cape" }
      ],
      "overlay_color": { "r": 1.0, "g": 1.0, "b": 1.0, "a": 1.0 },
      "is_hurt_color": { "r": 1.0, "g": 1.0, "b": 1.0, "a": 1.0 },
      "on_fire_color": { "r": 1.0, "g": 1.0, "b": 1.0, "a": 1.0 },
      "ignore_lighting": true
    }
  }
}
