        "shield_block_main_hand": "animation.player.shield_block_main_hand",
        "shield_block_off_hand": "animation.player.shield_block_off_hand",
        "blink": "controller.animation.persona.blink",
        "tooting_goat_horn": "animation.humanoid.tooting_goat_horn",
        "holding_brush": "animation.humanoid.holding_brush",
        "brushing": "animation.humanoid.brushing",

        // Blurry's Java PvP
				"first_person_sword_cooldown": "animation.cooldown.sword",
				"first_person_axe_cooldown": "animation.cooldown.axe",
				"first_person_mace_cooldown": "animation.cooldown.mace",
				"attack_rotation_custom_sword": "animation.player.first_person.attack_rotation_custom_sword",
				"attack_rotation_custom_axe": "animation.player.first_person.attack_rotation_custom_axe",
				"cooldown_sword": "controller.animation.cooldown_sword",
				"cooldown_axe": "controller.animation.cooldown_axe",
				"cooldown_mace": "controller.animation.cooldown_mace",
				"shield_offhand": "animation.shield.wield_off_hand_first_person_blocking2",
				"shield_mainhand": "animation.shield.wield_mian_hand_first_person_blocking2",
				"animation.shield.wield_main_hand_first_person": "animation.shield.wield_main_hand_first_person",
				"animation.shield.wield_off_hand_first_person": "animation.shield.wield_off_hand_first_person",
				"animation.shield.wield_main_hand_first_person_block": "animation.shield.wield_main_hand_first_person_block",
				"animation.shield.wield_off_hand_first_person_block": "animation.shield.wield_off_hand_first_person_block"
			},
			"render_controllers": [
				{ "controller.render.player.first_person_spectator": "variable.is_first_person && query.is_spectator" },
				{ "controller.render.player.third_person_spectator": "!variable.is_first_person && !variable.map_face_icon && query.is_spectator" },
				{ "controller.render.player.first_person": "variable.is_first_person && !query.is_spectator" },
				{ "controller.render.player.third_person": "!variable.is_first_person && !variable.map_face_icon && !query.is_spectator" },
				{ "controller.render.player.map": "variable.map_face_icon" },
        { "controller.render.player.cape": "!variable.is_first_person || !variable.map_face_icon && !query.is_spectator" },

        { "controller.render.outline_layer": "variable.slim && !variable.is_first_person" },
        { "controller.render.wide_outline_layer": "variable.wide && !variable.is_first_person" },

        { "controller.render.outline_cape_layer": "!query.is_item_name_any('slot.armor.chest', 0, 'minecraft:elytra') && !variable.is_first_person" },
