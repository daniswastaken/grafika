{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "minecraft:hopper_minecart",
      "min_engine_version": "1.8.0",
      "materials": {
        "default": "general_outline_base",
        "outline": "general_outline"
      },
      "textures": {
        "default": "textures/entity/minecart",
        "outline": "textures/ui/White"
      },
      "geometry": {
        "default": "geometry.minecart.v1.8",
        "outline": "geometry.minecart.v1.8.outline"
      },
      "scripts": {
        "pre_animation": [
          "variable.hurt = query.hurt_time - query.frame_alpha;"
        ],
        "animate": [
          "move"
        ]
      },
      "animations": {
        "move": "animation.minecart.move"
      },
      "render_controllers": [
        "controller.render.minecart",
        "controller.render.entity.outline"
      ]
    }
  }
}